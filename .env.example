# Copy to .env and fill in real values. All vars are validated at startup in
# src/core/env.ts — a missing one exits the process.

# PostgreSQL connection string (Postgres + PostGIS).
# With the bundled docker-compose: postgres://postgres:postgres@localhost:5432/lumotrack
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lumotrack

# development | production | test
ENVIRONMENT=development

# Claude API key
ANTHROPIC_API_KEY=

# Allowed CORS origin(s), comma-separated (e.g. http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Redis connection string (used by BullMQ).
# With the bundled docker-compose: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Auth encryption key (use a long random string)
BETTER_AUTH_SECRET=
# Auth base URL
BETTER_AUTH_URL=http://localhost:3000

# Resend API key for transactional email
RESEND_API_KEY=

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio sender phone number (E.164 format, e.g. +15551234567)
TWILIO_PHONE_NUMBER=
